# Local environment template for raw-data acquisition.
# Copy this file to .env or set the variables manually in your shell.
# Never commit real API tokens.

STOCKDATA_API_TOKEN=your_stockdata_token_here
# STOCKDATA_API_KEY=your_stockdata_token_here

# StockData news articles requested per day.
# Set this to match your API plan. Use 25 for plans that allow 25 articles per request.
NEWS_LIMIT_PER_DAY=25
